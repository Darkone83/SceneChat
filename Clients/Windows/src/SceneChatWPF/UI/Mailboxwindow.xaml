<Window x:Class="SceneChatWPF.UI.MailboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mailbox"
        Width="680" Height="460"
        Background="{StaticResource BrBg}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Mailbox" FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource BrAccent}"
                       VerticalAlignment="Center"/>
            <Button Content="Compose" Width="90" Height="30"
                    HorizontalAlignment="Right"
                    Style="{StaticResource BtnPrimary}"
                    Click="BtnCompose_Click"/>
        </Grid>

        <!-- List + read pane -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="MailListBox" Grid.Column="0"
                     Background="{StaticResource BrSurface}"
                     BorderThickness="0"
                     SelectionChanged="MailListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Sender}"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource BrPurple}"/>
                            <TextBlock Text="{Binding Timestamp}"
                                       FontSize="10"
                                       Foreground="{StaticResource BrMuted}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtFrom" Grid.Row="0"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrPurple}"/>
                <TextBlock x:Name="TxtTimestamp" Grid.Row="1"
                           FontSize="10"
                           Foreground="{StaticResource BrMuted}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="TxtBody" Grid.Row="2"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BrBg}"
                         Foreground="{StaticResource BrText}"
                         BorderThickness="0"/>
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button x:Name="BtnReply" Content="Reply"
                            Width="80" Height="30" Margin="0,0,8,0"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="{StaticResource BrAccent}"
                            Click="BtnReply_Click"/>
                    <Button x:Name="BtnDelete" Content="Delete"
                            Width="80" Height="30"
                            Background="Transparent" BorderBrush="#333333"
                            Foreground="{StaticResource BrRed}"
                            Click="BtnDelete_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
