<Window x:Class="SceneChatWPF.UI.EmojiPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emoji" Width="420" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        BorderBrush="#222222"
        BorderThickness="1">

    <Grid Margin="8">
        <WrapPanel x:Name="EmojiPanel"
                   Orientation="Horizontal"
                   ItemWidth="40"
                   ItemHeight="40"/>
    </Grid>
</Window>
