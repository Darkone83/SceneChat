<Window x:Class="SceneChatWPF.UI.EmojiPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emoji" Width="360" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBg}"
        BorderBrush="{StaticResource BrBorder}"
        BorderThickness="1">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
        <WrapPanel x:Name="EmojiPanel" Orientation="Horizontal"/>
    </ScrollViewer>
</Window>
