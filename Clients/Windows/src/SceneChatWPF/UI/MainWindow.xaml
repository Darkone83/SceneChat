<Window x:Class="SceneChatWPF.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SceneChat v1.1"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BrBg}"
        WindowStartupLocation="CenterScreen">

    <Window.Icon>
        <BitmapImage UriSource="/Resources/scenechat_logo.png"/>
    </Window.Icon>

    <Grid>
        <!-- Login view -->
        <Grid x:Name="LoginView" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">

                <!-- Logo -->
                <Image Source="/Resources/scenechat_logo.png"
                       Width="96" Height="96"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

                <!-- Title -->
                <TextBlock Text="SCENECHAT"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource BrAccent}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Team Resurgent / Darkone83"
                           FontSize="11"
                           Foreground="{StaticResource BrPurple}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,28"/>

                <!-- Card -->
                <Border Background="{StaticResource BrSurface}"
                        BorderBrush="{StaticResource BrBorder}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="32">
                    <StackPanel>

                        <TextBlock Text="SERVER" FontSize="10" Foreground="{StaticResource BrMuted}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtServer" Margin="0,0,0,12"
                                 ToolTip="hostname or IP address"/>

                        <TextBlock Text="USERNAME" FontSize="10" Foreground="{StaticResource BrMuted}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtUsername" Margin="0,0,0,12"/>

                        <TextBlock Text="PASSWORD" FontSize="10" Foreground="{StaticResource BrMuted}"
                                   Margin="0,0,0,4"/>
                        <PasswordBox x:Name="TxtPassword" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnLogin"    Grid.Column="0"
                                    Style="{StaticResource BtnPrimary}"
                                    Content="LOGIN"
                                    Click="BtnLogin_Click"/>
                            <Button x:Name="BtnRegister" Grid.Column="2"
                                    Style="{StaticResource BtnSecondary}"
                                    Content="REGISTER"
                                    Click="BtnRegister_Click"/>
                        </Grid>

                        <TextBlock x:Name="TxtLoginStatus"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{StaticResource BrRed}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Chat view -->
        <Grid x:Name="ChatView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="54"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrSurface}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TxtRoomName"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource BrAccent}"
                               Text="SceneChat"/>

                    <TextBlock x:Name="TxtLoggedInUser"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource BrPurple}"/>

                    <Button Grid.Column="3"
                            Content="Logout"
                            Height="30"
                            FontSize="12"
                            Background="Transparent"
                            BorderBrush="#333333"
                            Foreground="{StaticResource BrMuted}"
                            VerticalAlignment="Center"
                            Click="BtnLogout_Click"/>
                </Grid>
            </Border>

            <!-- Main area: sidebar + feed -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Room sidebar -->
                <Grid Grid.Column="0" Background="{StaticResource BrSurface}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="ROOMS"
                               FontSize="10"
                               Foreground="{StaticResource BrMuted}"
                               Padding="14,8,14,4"/>
                    <ListBox x:Name="RoomListBox"
                             Grid.Row="1"
                             SelectionChanged="RoomListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="{StaticResource BrBorder}"/>

                <!-- Message feed -->
                <RichTextBox x:Name="FeedBox"
                             Grid.Column="2"
                             Background="{StaticResource BrBg}"
                             BorderThickness="0"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="13"
                             Foreground="{StaticResource BrText}"
                             Padding="12,8"/>
            </Grid>

            <!-- Input bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrSurface}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtMessage"
                             Grid.Column="0"
                             KeyDown="TxtMessage_KeyDown"
                             VerticalContentAlignment="Center"/>

                    <Button Grid.Column="2"
                            Content="😊"
                            Width="36" Height="36"
                            FontSize="16"
                            Background="#1A1A1A"
                            BorderBrush="#333333"
                            Click="BtnEmoji_Click"
                            ToolTip="Emoji picker"/>

                    <Button Grid.Column="4"
                            Style="{StaticResource BtnPrimary}"
                            Content="Send"
                            Click="BtnSend_Click"/>
                </Grid>
            </Border>
            <!-- Status bar -->
            <Border Grid.Row="3"
                    Background="{StaticResource BrSurface}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="TxtStatus"
                           Text="Not connected"
                           FontSize="11"
                           Foreground="{StaticResource BrMuted}"
                           Padding="12,0"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>
